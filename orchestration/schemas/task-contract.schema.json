{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chris-page-gov.github.io/okf-govuk-content/schemas/task-contract.v1.json",
  "title": "AF/HF GOV.UK OKF task contract",
  "type": "object",
  "required": ["schema_version", "task_id", "objective", "dependencies", "requirement_ids", "model_profile", "output_artifacts", "acceptance_tests", "budgets", "retry_policy", "on_block"],
  "properties": {
    "schema_version": {"const": 1},
    "task_id": {"pattern": "^[A-Z][0-9]-[0-9]{2}$"},
    "objective": {"type": "string", "minLength": 3},
    "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "requirement_ids": {"type": "array", "items": {"pattern": "^REQ-[0-9]{3}$"}, "minItems": 1, "uniqueItems": true},
    "model_profile": {"enum": ["deterministic", "coding_and_research", "independent_verification", "human"]},
    "allowed_sources": {"type": "array", "items": {"type": "string"}},
    "output_artifacts": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "acceptance_tests": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "budgets": {"type": "object"},
    "retry_policy": {"type": "object"},
    "human_gate": {"type": ["string", "null"]},
    "on_block": {"enum": ["continue_independent", "checkpoint", "escalate"]}
  },
  "additionalProperties": true
}

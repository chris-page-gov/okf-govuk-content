{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chris-page-gov.github.io/okf-govuk-content/semantic/schemas/entity.schema.json",
  "title": "GOV.UK OKF source entity",
  "description": "Discriminated source-native entity shapes. Evidence and Assertion use their dedicated schemas.",
  "oneOf": [
    {"$ref": "#/$defs/ContentItem"},
    {"$ref": "#/$defs/Document"},
    {"$ref": "#/$defs/Edition"},
    {"$ref": "#/$defs/Route"},
    {"$ref": "#/$defs/BasePath"},
    {"$ref": "#/$defs/RenderedPage"},
    {"$ref": "#/$defs/Part"},
    {"$ref": "#/$defs/ContentType"},
    {"$ref": "#/$defs/SchemaFamily"},
    {"$ref": "#/$defs/Organisation"},
    {"$ref": "#/$defs/Taxon"},
    {"$ref": "#/$defs/WorldTaxon"},
    {"$ref": "#/$defs/Browse"},
    {"$ref": "#/$defs/MainstreamBrowsePage"},
    {"$ref": "#/$defs/StepByStep"},
    {"$ref": "#/$defs/Service"},
    {"$ref": "#/$defs/GovernmentService"},
    {"$ref": "#/$defs/Collection"},
    {"$ref": "#/$defs/Attachment"},
    {"$ref": "#/$defs/Distribution"},
    {"$ref": "#/$defs/MachineRepresentation"},
    {"$ref": "#/$defs/Redirect"},
    {"$ref": "#/$defs/Withdrawal"},
    {"$ref": "#/$defs/Replacement"},
    {"$ref": "#/$defs/Tombstone"},
    {"$ref": "#/$defs/EvidenceSource"},
    {"$ref": "#/$defs/AcquisitionActivity"},
    {"$ref": "#/$defs/InferenceActivity"},
    {"$ref": "#/$defs/ConstraintRecord"}
  ],
  "$defs": {
    "ContentItem": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["contentId", "basePath", "canonicalUrl", "contentType", "schemaFamily"],
          "properties": {
            "@type": {"const": "govuk:ContentItem"},
            "contentId": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
            },
            "basePath": {"type": "string", "pattern": "^/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "contentType": {"$ref": "common.schema.json#/$defs/iriReference"},
            "schemaFamily": {"$ref": "common.schema.json#/$defs/iriReference"}
          }
        }
      ]
    },
    "Document": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["contentItem", "locale"],
          "properties": {
            "@type": {"const": "govuk:Document"},
            "contentItem": {"$ref": "common.schema.json#/$defs/iriReference"},
            "locale": {
              "type": "string",
              "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
            }
          }
        }
      ]
    },
    "Edition": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["document", "editionId", "lifecycleState", "effectiveAt"],
          "properties": {
            "@type": {"const": "govuk:Edition"},
            "document": {"$ref": "common.schema.json#/$defs/iriReference"},
            "editionId": {"type": "string", "minLength": 1},
            "lifecycleState": {
              "enum": ["draft", "published", "withdrawn", "superseded", "unpublished", "unknown"]
            },
            "effectiveAt": {"$ref": "common.schema.json#/$defs/dateTime"}
          }
        }
      ]
    },
    "Route": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["path", "canonicalUrl", "routeKind"],
          "properties": {
            "@type": {"const": "govuk:Route"},
            "path": {"type": "string", "pattern": "^/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "routeKind": {"enum": ["exact", "prefix", "redirect", "gone", "tombstone", "unknown"]}
          }
        }
      ]
    },
    "BasePath": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["path", "canonicalUrl"],
          "properties": {
            "@type": {"const": "govuk:BasePath"},
            "path": {"type": "string", "pattern": "^/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"}
          }
        }
      ]
    },
    "RenderedPage": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["route", "canonicalUrl", "observedAt", "bodySha256"],
          "properties": {
            "@type": {"const": "govuk:RenderedPage"},
            "route": {"$ref": "common.schema.json#/$defs/iriReference"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "observedAt": {"$ref": "common.schema.json#/$defs/dateTime"},
            "bodySha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        }
      ]
    },
    "Part": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["contentItem", "partKind", "position", "sourceLocator"],
          "properties": {
            "@type": {"const": "govuk:Part"},
            "contentItem": {"$ref": "common.schema.json#/$defs/iriReference"},
            "partKind": {"type": "string", "minLength": 1},
            "position": {"type": "integer", "minimum": 0},
            "sourceLocator": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "ContentType": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["sourceName"],
          "properties": {
            "@type": {"const": "govuk:ContentType"},
            "sourceName": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "SchemaFamily": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["schemaName", "schemaUri", "sourceCommit"],
          "properties": {
            "@type": {"const": "govuk:SchemaFamily"},
            "schemaName": {"type": "string", "minLength": 1},
            "schemaUri": {"$ref": "common.schema.json#/$defs/iri"},
            "sourceCommit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}
          }
        }
      ]
    },
    "Organisation": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["slug", "canonicalUrl", "organisationStatus"],
          "properties": {
            "@type": {"const": "govuk:Organisation"},
            "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "organisationStatus": {"enum": ["live", "closed", "exempt", "unknown"]}
          }
        }
      ]
    },
    "Taxon": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["basePath", "canonicalUrl", "taxonomyKind"],
          "properties": {
            "@type": {"const": "govuk:Taxon"},
            "basePath": {"type": "string", "pattern": "^/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "taxonomyKind": {"enum": ["topic", "world", "navigation", "other"]}
          }
        }
      ]
    },
    "WorldTaxon": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["basePath", "canonicalUrl", "locale"],
          "properties": {
            "@type": {"const": "govuk:WorldTaxon"},
            "basePath": {"type": "string", "pattern": "^/world/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "locale": {"type": "string", "minLength": 2}
          }
        }
      ]
    },
    "Browse": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["basePath", "canonicalUrl", "browseKind"],
          "properties": {
            "@type": {"const": "govuk:Browse"},
            "basePath": {"type": "string", "pattern": "^/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "browseKind": {"enum": ["mainstream_browse", "curated_browse", "other"]}
          }
        }
      ]
    },
    "MainstreamBrowsePage": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["basePath", "canonicalUrl"],
          "properties": {
            "@type": {"const": "govuk:MainstreamBrowsePage"},
            "basePath": {"type": "string", "pattern": "^/browse/"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"}
          }
        }
      ]
    },
    "StepByStep": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["canonicalUrl", "stepCount"],
          "properties": {
            "@type": {"const": "govuk:StepByStep"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "stepCount": {"type": "integer", "minimum": 1}
          }
        }
      ]
    },
    "Service": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["canonicalUrl", "serviceStatus", "serviceBasis"],
          "properties": {
            "@type": {"const": "govuk:Service"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "serviceStatus": {"enum": ["live", "beta", "retired", "unknown"]},
            "serviceBasis": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "GovernmentService": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["canonicalUrl", "serviceStatus", "serviceBasis"],
          "properties": {
            "@type": {"const": "govuk:GovernmentService"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "serviceStatus": {"enum": ["live", "beta", "retired", "unknown"]},
            "serviceBasis": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "Collection": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["canonicalUrl", "collectionKind"],
          "properties": {
            "@type": {"const": "govuk:Collection"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "collectionKind": {"enum": ["collection", "step_by_step", "curated_journey", "other"]}
          }
        }
      ]
    },
    "Attachment": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["contentItem", "canonicalUrl", "mimeType", "filename", "rightsStatus"],
          "properties": {
            "@type": {"const": "govuk:Attachment"},
            "contentItem": {"$ref": "common.schema.json#/$defs/iriReference"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "mimeType": {"type": "string", "pattern": "^[^/ ]+/[^/ ]+$"},
            "filename": {"type": "string", "minLength": 1},
            "byteSize": {"type": "integer", "minimum": 0},
            "pageCount": {"type": "integer", "minimum": 0},
            "accessibility": {"type": "string"},
            "rightsStatus": {
              "enum": ["ogl_v3_except_where_otherwise_stated", "source_declared", "review_required", "restricted", "unknown"]
            }
          }
        }
      ]
    },
    "Distribution": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["resource", "canonicalUrl", "mimeType", "rightsStatus"],
          "properties": {
            "@type": {"const": "govuk:Distribution"},
            "resource": {"$ref": "common.schema.json#/$defs/iriReference"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "mimeType": {"type": "string", "pattern": "^[^/ ]+/[^/ ]+$"},
            "rightsStatus": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "MachineRepresentation": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["contentItem", "canonicalUrl", "representationType", "mimeType"],
          "properties": {
            "@type": {"const": "govuk:MachineRepresentation"},
            "contentItem": {"$ref": "common.schema.json#/$defs/iriReference"},
            "canonicalUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "representationType": {"type": "string", "minLength": 1},
            "mimeType": {"type": "string", "pattern": "^[^/ ]+/[^/ ]+$"}
          }
        }
      ]
    },
    "Redirect": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["fromRoute", "target", "httpStatus", "observedAt"],
          "properties": {
            "@type": {"const": "govuk:Redirect"},
            "fromRoute": {"$ref": "common.schema.json#/$defs/iriReference"},
            "target": {"$ref": "common.schema.json#/$defs/iriReference"},
            "httpStatus": {"type": "integer", "minimum": 300, "maximum": 399},
            "observedAt": {"$ref": "common.schema.json#/$defs/dateTime"}
          }
        }
      ]
    },
    "Withdrawal": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["contentItem", "notice", "observedAt"],
          "properties": {
            "@type": {"const": "govuk:Withdrawal"},
            "contentItem": {"$ref": "common.schema.json#/$defs/iriReference"},
            "notice": {"type": "string", "minLength": 1},
            "observedAt": {"$ref": "common.schema.json#/$defs/dateTime"}
          }
        }
      ]
    },
    "Replacement": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["original", "replacement", "observedAt"],
          "properties": {
            "@type": {"const": "govuk:Replacement"},
            "original": {"$ref": "common.schema.json#/$defs/iriReference"},
            "replacement": {"$ref": "common.schema.json#/$defs/iriReference"},
            "observedAt": {"$ref": "common.schema.json#/$defs/dateTime"}
          }
        }
      ]
    },
    "Tombstone": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["route", "tombstoneKind", "observedAt"],
          "properties": {
            "@type": {"const": "govuk:Tombstone"},
            "route": {"$ref": "common.schema.json#/$defs/iriReference"},
            "tombstoneKind": {"enum": ["gone", "withdrawn", "unpublished", "not_found", "unknown"]},
            "observedAt": {"$ref": "common.schema.json#/$defs/dateTime"}
          }
        }
      ]
    },
    "EvidenceSource": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["evidenceUrl", "retrievedAt", "sha256", "sourceAuthority"],
          "properties": {
            "@type": {"const": "govuk:EvidenceSource"},
            "evidenceUrl": {"$ref": "common.schema.json#/$defs/iri"},
            "retrievedAt": {"$ref": "common.schema.json#/$defs/dateTime"},
            "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "sourceAuthority": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "AcquisitionActivity": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["startedAt", "endedAt", "softwareVersion", "sourceSystem"],
          "properties": {
            "@type": {"const": "govuk:AcquisitionActivity"},
            "startedAt": {"$ref": "common.schema.json#/$defs/dateTime"},
            "endedAt": {"$ref": "common.schema.json#/$defs/dateTime"},
            "softwareVersion": {"type": "string", "minLength": 1},
            "sourceSystem": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "InferenceActivity": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["startedAt", "endedAt", "derivationMethod"],
          "properties": {
            "@type": {"const": "govuk:InferenceActivity"},
            "startedAt": {"$ref": "common.schema.json#/$defs/dateTime"},
            "endedAt": {"$ref": "common.schema.json#/$defs/dateTime"},
            "derivationMethod": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "ConstraintRecord": {
      "allOf": [
        {"$ref": "common.schema.json#/$defs/commonEntity"},
        {
          "type": "object",
          "required": ["constraintClass", "reason", "constraintStatus", "evidence", "owner", "reviewDate"],
          "properties": {
            "@type": {"const": "govuk:ConstraintRecord"},
            "constraintClass": {"type": "string", "minLength": 1},
            "reason": {"type": "string", "minLength": 1},
            "constraintStatus": {"enum": ["active", "blocked", "resolved", "expired"]},
            "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "common.schema.json#/$defs/iriReference"}},
            "owner": {"type": "string", "minLength": 1},
            "reviewDate": {"type": "string", "format": "date"}
          }
        }
      ]
    }
  }
}

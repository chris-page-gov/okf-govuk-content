  "source_access_history": [
    {
      "checked_at": "2026-07-11T23:21:00Z",
      "constraint": "The CMU ACT-R host failed safe Python/OpenSSL negotiation with DH_KEY_TOO_SMALL. TLS policy was not weakened.",
      "original_url": "https://act-r.psy.cmu.edu/wordpress/wp-content/uploads/2012/12/280uir-1999-05-pirolli.pdf",
      "resolution": "Use the HTTPS ResearchGate publication record and author-provided full-text copy, retaining DOI 10.1037/0033-295X.106.4.643 for identity."
    },
    {
      "checked_at": "2026-07-12T07:18:36Z",
      "constraint": "The secure ResearchGate publication record returned HTTP 403 to three bounded identified verifier attempts; a separate strict-TLS request to the exact author-uploaded PDF also returned HTTP 403. No anti-bot bypass was attempted.",
      "original_url": "https://www.researchgate.net/publication/229101074_Information_Foraging",
      "resolution": "The author-uploaded copy and DOI identity remain documented, but the two dependent released citations stay blocked until a public reproducible copy can be fetched under normal access controls. TLS and access controls must not be weakened."
    },
    {
      "checked_at": "2026-07-12T07:34:00Z",
      "constraint": "The original full text remains inaccessible under safe reproducible transport, so it cannot support section-level release claims.",
      "original_url": "https://www.researchgate.net/publication/229101074_Information_Foraging",
      "resolution": "Use the strict-TLS Crossref DOI record only for title, authors, journal, publication date, pages, publisher and DOI identity; do not infer full-text content."
    },
    {
      "checked_at": "2026-07-12T07:38:00Z",
      "constraint": "The two National Archives HTML licensing URLs presented a self-signed certificate in the Python default strict chain during three bounded verifier attempts.",
      "original_url": "https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/",
      "resolution": "Use The National Archives official CDN OGL user guidance PDF under strict TLS; preserve the HTML transport failure and do not weaken certificate verification."
    },
    {
      "checked_at": "2026-07-12T07:38:00Z",
      "constraint": "The OpenAI BrowseComp article returned HTTP 403 to the identified verifier.",
      "original_url": "https://openai.com/index/browsecomp/",
      "resolution": "Use the official cdn.openai.com BrowseComp paper under strict TLS; do not attempt an access-control bypass."
    },
    {
      "checked_at": "2026-07-12T07:41:00Z",
      "constraint": "The National Archives official CDN OGL guidance fallback presented the same self-signed certificate chain to Python default strict verification.",
      "original_url": "https://cdn.nationalarchives.gov.uk/documents/information-management/ogl-user-guidance.pdf",
      "resolution": "Use the current GOV.UK Knowledge Asset Commercialisation Guide sections 7.5 and 7.6 for the OGL default, characteristics and exclusions; retain all National Archives transport failures and do not weaken TLS."
    }
  ],

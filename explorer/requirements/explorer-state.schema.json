{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chris-page-gov.github.io/okf-govuk-content/explorer/explorer-state.schema.json",
  "title": "What’s on GOV.UK replayable Explorer state",
  "x-url-codec": {
    "query_parameters": ["q", "facet", "view", "mode", "lang", "lifecycle", "jurisdiction", "page", "snapshot", "pin"],
    "canonical_record_route": "decoded URL fragment",
    "legacy_alias": "the route query parameter is accepted on input and canonicalised to the URL fragment"
  },
  "type": "object",
  "required": ["query", "facets", "view", "mode", "language", "route", "page", "snapshot", "pins"],
  "properties": {
    "query": { "type": "string", "maxLength": 240 },
    "facets": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "maxItems": 40,
        "uniqueItems": true,
        "items": { "type": "string", "maxLength": 256 }
      }
    },
    "view": { "enum": ["results", "browse", "relationships", "timeline", "compare"] },
    "mode": { "enum": ["simple", "explore", "evidence"] },
    "language": { "type": "string", "pattern": "^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$" },
    "route": { "type": "string", "maxLength": 768 },
    "lifecycle": { "type": "string", "maxLength": 80 },
    "jurisdiction": { "type": "string", "maxLength": 80 },
    "page": { "type": "integer", "minimum": 1, "maximum": 100000 },
    "snapshot": { "type": "string", "maxLength": 160 },
    "pins": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "maxLength": 768 }
    }
  },
  "additionalProperties": false
}

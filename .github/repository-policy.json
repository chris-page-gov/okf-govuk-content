{
  "schema": "govuk-okf-repository-policy.v1",
  "repository": "chris-page-gov/okf-govuk-content",
  "default_branch": "main",
  "branch_protection": {
    "api_endpoint": "/repos/chris-page-gov/okf-govuk-content/branches/main/protection",
    "policy_path": ".github/branch-protection.json",
    "required_check_contexts": [
      "validate"
    ]
  },
  "codeowners": {
    "path": ".github/CODEOWNERS",
    "required_owner": "@chris-page-gov",
    "required_patterns": [
      "*",
      "/.github/",
      "/scripts/check_repository_policy.py",
      "/src/govuk_okf/repository_policy.py"
    ]
  },
  "release": {
    "candidate_tag_pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)-rc\\.[1-9][0-9]*$",
    "final_tag_pattern": "^v(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$",
    "require_annotated_tag": true,
    "signature_policy": "verify_if_present",
    "require_main_ancestry": true,
    "candidate_gate": "scripts/check_release.py --publication-ready",
    "final_gate": "scripts/check_release.py --finalized",
    "artifact_attestations_required": true,
    "checksums_required": true,
    "immutable_artifact_name": "verified-pages-${{ github.ref_name }}-${{ github.sha }}",
    "immutable_releases": {
      "api_endpoint": "/repos/chris-page-gov/okf-govuk-content/immutable-releases",
      "api_version": "2026-03-10",
      "enabled_required": true,
      "draft_first": true,
      "verify_exact_assets_before_publish": true,
      "verify_immutable_after_publish": true
    },
    "workflow": ".github/workflows/release.yml"
  },
  "release_metadata": {
    "citation_path": "CITATION.cff",
    "citation_version_source": "pyproject.toml:project.version",
    "doi": null
  },
  "pages": {
    "workflow": ".github/workflows/pages.yml",
    "api_endpoint": "/repos/chris-page-gov/okf-govuk-content/pages",
    "api_version": "2026-03-10",
    "expected_url": "https://chris-page-gov.github.io/okf-govuk-content/",
    "build_type": "workflow",
    "public": true,
    "https_enforced": true,
    "source": "verified same-origin Pages site artifact only",
    "rebuild_forbidden": true,
    "post_deploy_smoke_required": true,
    "site_budget_bytes": 950000000,
    "data_plane": "same-origin-github-pages-range-packs",
    "pack_suffix": ".pack.gz",
    "browser_release_asset_fetch": false,
    "live_range_smoke_required": true
  },
  "workflow_policy": {
    "allowed_action_owners": [
      "actions",
      "github"
    ],
    "forbidden_events": [
      "pull_request_target"
    ],
    "forbidden_tokens": [
      "permissions: write-all",
      "persist-credentials: true",
      "--clobber"
    ]
  }
}

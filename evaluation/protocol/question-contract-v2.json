{
  "claim_boundary": "The contract verifies metadata discovery gold. It does not claim that metadata alone answers body-content questions or that unauthorised human research has been completed.",
  "contract_id": "govuk-question-release-contract-v2",
  "expected_questions_per_persona_suite": 100,
  "expected_questions_per_story": 100,
  "expected_stories_per_primary_persona": {
    "maximum": 12,
    "minimum": 6
  },
  "gold_gate": {
    "answerable": "at least one verified content ID or URL plus source record and evidence hashes",
